
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TempUser {
  id   String @id @default(uuid())

  name  String
  email String @unique
  password String

  verificationToken String? @unique
  verificationTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GENDER {
  MALE
  FEMALE
  OTHER
}

model User {
  id   String @id @default(uuid())

  name  String
  email String @unique
  password String
  gender GENDER?

  isVerified Boolean @default(false)

  passwordResetToken String? @unique
  passwordResetTokenExpiry DateTime?

  isAdmin Boolean @default(false)

  addresses Address[]
  cart Cart?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(uuid())

  name String
  slug String @unique
  description String?

  price Decimal @db.Decimal(10, 2)

  stock Int @default(0)

  images ProductImage[]

  isPublished Boolean @default(false)

 cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id String @id @default(uuid())

  url String
  fileId String

  isCover Boolean @default(false)

  productId String
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

enum ADDRESS_TYPE {
  HOME
  WORK
}

model Address {
  id String @id @default(uuid())

  name String
  mobile String

  pinCode String
  state String
  locality String
  city String

  addressLine1 String

  addressType ADDRESS_TYPE @default(HOME)

  userId String
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Cart {
  id String @id @default(uuid())

  items CartItem[]

  userId String @unique
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id String @id @default(uuid())

  quantity Int @default(1)

  productId String
  product Product @relation(fields: [productId], references: [id])


  cartId String
  cart Cart @relation(fields: [cartId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}